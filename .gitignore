# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# IDE
.vscode/
.idea/

# Understand-anything
.understand-anything/

# Models (large files, keep only in models/)
*.pt
!models/*.pt

# Generated outputs
assets/outputs/images/*
!assets/outputs/images/.gitkeep
assets/outputs/videos/*
!assets/outputs/videos/.gitkeep
assets/outputs/screenshots/*
!assets/outputs/screenshots/.gitkeep

# Exclude CUDA Venv and local history
.venv-cuda/
assets/history.json

# Exclude local test inputs (keep only .gitkeep and lena.jpg)
assets/inputs/images/*
!assets/inputs/images/.gitkeep
!assets/inputs/images/lena.jpg
assets/inputs/videos/*
!assets/inputs/videos/.gitkeep

# Exclude submission package
submission_package/

